.env

# Backend directory exclusions
backend/bin/
backend/out/
backend/dist/
backend/target/

# Node Server artifacts
backend/server/node_modules/
backend/server/uploads/*
!backend/server/uploads/.gitkeep
backend/server/outputs/*
!backend/server/outputs/.gitkeep

